# Copie este arquivo para .env e ajuste os valores antes de subir o Docker Compose
# NUNCA commite o arquivo .env com senhas reais no repositório

# Banco de dados PostgreSQL
DB_URL=jdbc:postgresql://postgres:5432/gastos
DB_USER=gastos
DB_PASSWORD=gastos_dev_password

# JWT — TROQUE este valor em produção! Use uma string aleatória com pelo menos 256 bits.
# Se quiser usar um valor legível localmente, não precisa ser Base64. O backend aceita ambos.
JWT_SECRET=troque_este_segredo_em_producao_use_256bits
